<Window x:Class="ElyProxy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ElyProxy"
        Icon="/icon.ico"
        Width="920" Height="680"
        MinWidth="780" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        Foreground="#E2E8F0"
        FontFamily="Segoe UI"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Color x:Key="Bg1">#0D1117</Color>
        <Color x:Key="Bg2">#111827</Color>
        <Color x:Key="Bg3">#161E2E</Color>
        <Color x:Key="Bg4">#202A3A</Color>
        <Color x:Key="CardBg">#151B24</Color>
        <Color x:Key="Accent">#38BDF8</Color>
        <Color x:Key="AccentHover">#0EA5E9</Color>
        <Color x:Key="Green">#10B981</Color>
        <Color x:Key="GreenHover">#059669</Color>
        <Color x:Key="Red">#F43F5E</Color>
        <Color x:Key="RedHover">#E11D48</Color>
        <Color x:Key="FgPrimary">#F8FAFC</Color>
        <Color x:Key="FgSecondary">#9CA3AF</Color>
        <Color x:Key="FgDim">#6B7280</Color>
        <Color x:Key="Border">#273244</Color>

        <SolidColorBrush x:Key="Bg1Brush" Color="{StaticResource Bg1}"/>
        <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2}"/>
        <SolidColorBrush x:Key="Bg3Brush" Color="{StaticResource Bg3}"/>
        <SolidColorBrush x:Key="Bg4Brush" Color="{StaticResource Bg4}"/>
        <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardBg}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}"/>
        <SolidColorBrush x:Key="GreenHoverBrush" Color="{StaticResource GreenHover}"/>
        <SolidColorBrush x:Key="RedBrush" Color="{StaticResource Red}"/>
        <SolidColorBrush x:Key="RedHoverBrush" Color="{StaticResource RedHover}"/>
        <SolidColorBrush x:Key="FgBrush" Color="{StaticResource FgPrimary}"/>
        <SolidColorBrush x:Key="FgSecBrush" Color="{StaticResource FgSecondary}"/>
        <SolidColorBrush x:Key="FgDimBrush" Color="{StaticResource FgDim}"/>
        <SolidColorBrush x:Key="BorderBr" Color="{StaticResource Border}"/>

        <!-- ── TextBox ── -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource FgBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Button macro ── -->
        <ControlTemplate x:Key="BtnTpl" TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Accent (add) -->
        <Style x:Key="BtnAccent" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green (connect) -->
        <Style x:Key="BtnGreen" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource GreenHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red (disconnect / danger) -->
        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource RedBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource RedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource RedHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost (secondary) -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="#1E293B"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Link -->
        <Style x:Key="BtnLink" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource FgDimBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box"
                                    Width="18" Height="18"
                                    CornerRadius="5"
                                    Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBr}"
                                    BorderThickness="1"
                                    Margin="0,0,10,0">
                                <TextBlock x:Name="mark"
                                           Text="✓"
                                           Foreground="#0D1117"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="mark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="track"
                                Width="42"
                                Height="24"
                                CornerRadius="12"
                                Background="{StaticResource Bg4Brush}"
                                BorderBrush="{StaticResource BorderBr}"
                                BorderThickness="1">
                            <Ellipse x:Name="thumb"
                                     Width="18"
                                     Height="18"
                                     Fill="{StaticResource FgSecBrush}"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="thumb" Property="Fill" Value="#0D1117"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="track" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="210"/>
        </Style>

        <!-- ── ListView ── -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" SnapsToDevicePixels="True">
                            <ScrollViewer Padding="{TemplateBinding Padding}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="13,9"/>
            <Setter Property="Margin" Value="5,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Bg4Brush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#132A35"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="Bd" Property="Padding" Value="12,8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TabControl ── -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource FgDimBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8" Padding="16,8" Margin="0,0,6,8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource CardBrush}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BorderBr}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Bg2Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <DockPanel Grid.Row="0" Margin="2,0,2,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Telegram" Style="{StaticResource BtnLink}" Command="{Binding OpenTelegramCommand}"/>
                <Button Content="Discord" Style="{StaticResource BtnLink}" Command="{Binding OpenDiscordCommand}" Margin="10,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="ElyProxy" FontSize="21" FontWeight="Bold" Foreground="{StaticResource FgBrush}"/>
                <Border Width="6" Height="6" CornerRadius="3" Background="{StaticResource AccentBrush}" Margin="10,2,0,0"/>
                <TextBlock Text="Подключение..." Foreground="{StaticResource AccentBrush}" VerticalAlignment="Bottom"
                           FontSize="12" Margin="16,0,0,3"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </DockPanel>

        <!-- ═══ Tabs ═══ -->
        <TabControl Grid.Row="1" Margin="0,0,0,12">

            <!-- ─── Серверы ─── -->
            <TabItem Header="Серверы">
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBr}"
                        BorderThickness="1" CornerRadius="8" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView Grid.Row="0" ItemsSource="{Binding AllNodes}"
                                  SelectedItem="{Binding SelectedNode}" Margin="0,0,0,10">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                       FontWeight="Medium" Foreground="{StaticResource FgBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource FgDimBrush}" Margin="0,3,0,0">
                                                <Run Text="{Binding Address, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{StaticResource Bg4Brush}" CornerRadius="6"
                                                Padding="8,4" VerticalAlignment="Center" Margin="10,0">
                                            <TextBlock Text="{Binding TransportDisplay}" FontSize="10.5" Foreground="{StaticResource AccentBrush}"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding LatencyDisplay}" FontSize="11.5"
                                                   Foreground="{StaticResource FgSecBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Manual add -->
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource DarkTextBox}" FontSize="12"
                                     Text="{Binding ManualServerUri, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="Добавить" Style="{StaticResource BtnAccent}"
                                    Command="{Binding AddManualServerCommand}" Margin="8,0,0,0"/>
                        </Grid>

                        <!-- Actions -->
                        <WrapPanel Grid.Row="2" Orientation="Horizontal">
                            <Button Content="Подключить" Style="{StaticResource BtnGreen}"
                                    Command="{Binding ConnectCommand}" MinWidth="120"/>
                            <Button Content="Отключить" Style="{StaticResource BtnRed}"
                                    Command="{Binding DisconnectCommand}" Margin="6,0,0,0" MinWidth="110"/>
                            <Button Content="Пинг" Style="{StaticResource BtnGhost}"
                                    Command="{Binding PingAllCommand}" Margin="6,0,0,0"/>
                            <Button Content="В профиль" Style="{StaticResource BtnGhost}"
                                    Command="{Binding AddToProfileCommand}" Margin="6,0,0,0"/>
                            <Button Content="Копировать прокси" Style="{StaticResource BtnGhost}"
                                    Command="{Binding CopyProxyCommand}" Margin="6,0,0,0"/>
                            <Border Background="{StaticResource Bg2Brush}"
                                    BorderBrush="{StaticResource BorderBr}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,7"
                                    Margin="6,0,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Системный прокси"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FgBrush}"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"/>
                                    <CheckBox Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding SystemProxyEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ─── Подписки ─── -->
            <TabItem Header="Подписки">
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBr}"
                        BorderThickness="1" CornerRadius="8" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}" FontSize="12"
                                     Text="{Binding NewSubName, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" FontSize="12"
                                     Text="{Binding NewSubUrl, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="Добавить" Style="{StaticResource BtnAccent}"
                                    Command="{Binding AddSubscriptionCommand}" Margin="8,0,0,0"/>
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{Binding Subscriptions}"
                                  SelectedItem="{Binding SelectedSubscription}" Margin="0,0,0,10">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource FgBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Url}" FontSize="11" Foreground="{StaticResource FgDimBrush}"
                                                       Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{StaticResource Bg4Brush}" CornerRadius="6"
                                                Padding="8,4" VerticalAlignment="Center" Margin="10,0">
                                            <TextBlock FontSize="10.5" Foreground="{StaticResource AccentBrush}">
                                                <Run Text="{Binding Nodes.Count, Mode=OneWay}"/><Run Text=" серв."/>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Grid.Column="2" FontSize="11" Foreground="{StaticResource FgDimBrush}"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                   Text="{Binding LastUpdated, StringFormat='{}{0:dd.MM HH:mm}'}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <WrapPanel Grid.Row="2" Orientation="Horizontal">
                            <Button Content="Обновить" Style="{StaticResource BtnAccent}"
                                    Command="{Binding UpdateSubscriptionCommand}"/>
                            <Button Content="Обновить все" Style="{StaticResource BtnGhost}"
                                    Command="{Binding UpdateAllSubscriptionsCommand}" Margin="6,0,0,0"/>
                            <Button Content="Удалить" Style="{StaticResource BtnRed}"
                                    Command="{Binding RemoveSubscriptionCommand}" Margin="6,0,0,0"/>
                        </WrapPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ─── Профили ─── -->
            <TabItem Header="Профили">
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBr}"
                        BorderThickness="1" CornerRadius="8" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Profile list -->
                        <Grid Grid.Column="0" Margin="0,0,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource DarkTextBox}" FontSize="12"
                                         Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="+" Style="{StaticResource BtnAccent}"
                                        Command="{Binding CreateProfileCommand}" Margin="6,0,0,0"
                                        Padding="12,8" FontSize="14"/>
                            </Grid>

                            <ListView Grid.Row="1" ItemsSource="{Binding Profiles}"
                                      SelectedItem="{Binding SelectedProfile}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{StaticResource FgBrush}" FontWeight="Medium"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource FgDimBrush}" Margin="0,2,0,0">
                                                <Run Text="{Binding Nodes.Count, Mode=OneWay}"/><Run Text=" серверов"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <StackPanel Grid.Row="2" Margin="0,8,0,0">
                                <Button Content="Удалить профиль" Style="{StaticResource BtnRed}"
                                        Command="{Binding DeleteProfileCommand}"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <!-- Profile nodes -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListView Grid.Row="0" ItemsSource="{Binding ProfileNodes}"
                                      SelectedItem="{Binding SelectedProfileNode}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="55"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                           Foreground="{StaticResource FgBrush}" FontWeight="Medium"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource FgDimBrush}" Margin="0,2,0,0">
                                                    <Run Text="{Binding Address, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="{StaticResource Bg4Brush}" CornerRadius="6"
                                                    Padding="7,3" VerticalAlignment="Center" Margin="8,0">
                                                <TextBlock Text="{Binding TransportDisplay}" FontSize="10.5" Foreground="{StaticResource AccentBrush}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding LatencyDisplay}" FontSize="11"
                                                       Foreground="{StaticResource FgSecBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Подключить" Style="{StaticResource BtnGreen}"
                                        Command="{Binding ConnectFromProfileCommand}" MinWidth="110"/>
                                <Button Content="Убрать" Style="{StaticResource BtnRed}"
                                        Command="{Binding RemoveFromProfileCommand}" Margin="6,0,0,0"/>
                                <Button Content="Очистить" Style="{StaticResource BtnGhost}"
                                        Command="{Binding ClearProfileCommand}" Margin="6,0,0,0"/>
                                <Button Content="Экспорт" Style="{StaticResource BtnGhost}"
                                        Command="{Binding ExportProfileCommand}" Margin="6,0,0,0"/>
                                <Button Content="Импорт" Style="{StaticResource BtnGhost}"
                                        Command="{Binding ImportProfileCommand}" Margin="6,0,0,0"/>
                            </WrapPanel>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ─── Расширения ─── -->
            <TabItem Header="Расширения">
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBr}"
                        BorderThickness="1" CornerRadius="8" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="ZeroOmega" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource FgBrush}" Margin="0,0,0,10"/>

                        <Border Grid.Row="1"
                                Background="{StaticResource Bg2Brush}"
                                BorderBrush="{StaticResource BorderBr}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10"
                                Margin="0,0,0,14">
                            <TextBlock Text="Расширение стоит использовать только если не работает режим «Системный прокси»."
                                       FontSize="12.5"
                                       Foreground="{StaticResource FgSecBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
                            <Button Content="Firefox" Style="{StaticResource BtnAccent}"
                                    Command="{Binding OpenFirefoxExtensionCommand}" MinWidth="120"/>
                            <Button Content="Chrome" Style="{StaticResource BtnAccent}"
                                    Command="{Binding OpenChromeExtensionCommand}" MinWidth="120"
                                    Margin="8,0,0,0"/>
                        </WrapPanel>

                        <Button Grid.Row="3" Content="Скачать файл правил .sorl"
                                Style="{StaticResource BtnGhost}"
                                Command="{Binding ExportOmegaRulesCommand}"
                                HorizontalAlignment="Left" MinWidth="210"/>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ─── Настройки ─── -->
            <TabItem Header="Настройки">
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBr}"
                        BorderThickness="1" CornerRadius="8" Padding="18">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Запуск" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource FgBrush}" Margin="0,0,0,14"/>
                        <CheckBox Content="Запускать вместе с Windows"
                                  Style="{StaticResource DarkCheckBox}"
                                  IsChecked="{Binding AutoStartWithWindows, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Content="Подключаться к последнему серверу"
                                  Style="{StaticResource DarkCheckBox}"
                                  IsChecked="{Binding AutoConnect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Content="Переподключаться при обрыве"
                                  Style="{StaticResource DarkCheckBox}"
                                  IsChecked="{Binding AutoReconnect, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Интерфейс" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource FgBrush}" Margin="0,12,0,14"/>
                        <CheckBox Content="Показывать логи"
                                  Style="{StaticResource DarkCheckBox}"
                                  IsChecked="{Binding ShowLogs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Подписки" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource FgBrush}" Margin="0,12,0,14"/>
                        <TextBlock Text="Автообновление" FontSize="12"
                                   Foreground="{StaticResource FgSecBrush}" Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding SubscriptionUpdateIntervalOptions}"
                                  DisplayMemberPath="Value"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SubscriptionUpdateIntervalMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  HorizontalAlignment="Left"/>

                        <TextBlock Text="Разделение трафика" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource FgBrush}" Margin="0,18,0,14"/>
                        <TextBlock Text="Домены напрямую" FontSize="12"
                                   Foreground="{StaticResource FgSecBrush}" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding SystemProxyRulesText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="94"
                                 FontFamily="Cascadia Mono, Consolas, monospace"
                                 FontSize="12"
                                 Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="1" Content="Сбросить правила"
                                    Style="{StaticResource BtnGhost}"
                                    Command="{Binding ResetSystemProxyRulesCommand}"/>
                        </Grid>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ═══ Log ═══ -->
        <TextBox Grid.Row="2"
                 Style="{StaticResource DarkTextBox}"
                 Text="{Binding LogText, Mode=OneWay}"
                 Visibility="{Binding ShowLogs, Converter={StaticResource BoolToVis}}"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Height="112"
                 FontFamily="Cascadia Mono, Consolas, monospace"
                 FontSize="11"
                 Foreground="{StaticResource FgSecBrush}"
                 Margin="0,0,0,12"
                 x:Name="LogBox"
                 TextChanged="LogBox_TextChanged"/>

        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBr}"
                BorderThickness="1"
                CornerRadius="8" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,10,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource FgDimBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding ConnectionInfo}" FontSize="12"
                           Foreground="{StaticResource FgSecBrush}" VerticalAlignment="Center"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                           Margin="20,0"/>

                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource FgDimBrush}">
                    <Run Text="SOCKS5 "/><Run Text="{Binding SocksPort, Mode=OneWay}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
